{
  "name": "obsidian-floater",
  "version": "0.1.0",
  "description": "Standalone Make.md-style floating formatting bar for Obsidian.",
  "main": "main.js",
  "packageManager": "bun@1.2.19",
  "scripts": {
    "dev": "bun esbuild.config.mjs",
    "build": "bunx tsc -noEmit -skipLibCheck && bun esbuild.config.mjs production",
    "deploy": "scripts/deploy-to-obsidian.sh"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "formatting",
    "floating-toolbar"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.0",
    "@lezer/common": "^1.2.3",
    "@types/node": "^18.19.120",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.8",
    "obsidian": "^1.8.7",
    "typescript": "^5.9.2"
  }
}
